# Copy to .env (git-ignored) and fill in. Required only for scripts/run_mace.py
# (generating new heuristics with the LLM). Not needed to evaluate the shipped
# portfolios with scripts/evaluate_portfolio.py.

OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: override the default backbone model
# MACE_MODEL=google/gemini-3-flash-preview
